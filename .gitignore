# Dependencies
node_modules/
package-lock.json

# OpenClaw runtime
.openclaw/
.codegraph/
sessions/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Temp
*.tmp
*.bak
*.log

# Eval harness baseline snapshot (regenerated by `make eval --baseline`)
scripts/eval/.eval-baseline.json

# API keys / secrets
.env
*.key

# 私密配置（含网关/通道 token，禁止入库；改用 openclaw.json.example）
config/openclaw.json

# Build
dist/
build/

# Large binary
*.mp4
*.wav
*.psd

# IDE
.vscode/
.idea/
.obsidian/
# WorkBuddy/automation session dir (agent runtime state; not framework source)
.workbuddy/

# Auto-generated
.auto-gen/
瓶颈检测/
心跳日志/
# generated proposals from `make evolve` (not published)
insights-out/

# Local collected insights (local data; the real source is the user's own
# collected material — set OPENCLAW_INSIGHTS_DIR or drop files in ./insights;
# examples/insights/ ships as a neutral template sample)
/insights/

# Agent run traces (observability; regenerated each run, not published)
.agent-runs/

# Generated framework-state dashboard (static HTML, regenerated by `make dashboard`)
.dashboard/

# Generated release notes (written by `make release-notes` / release.yml)
release-notes.md

# Agent temp comment file
.agent-comment.tmp

# ===== 用户私有数据（非框架，本地保留、不随公开仓库发布）=====
# 以下目录是项目所有者本人的小说/日志/知识库/共享池等真实产物，
# 含个人路径（如 C:\Users\Administrator），不随框架发布。
# 任何人 clone 本仓库后，只需配置 .env 即可运行框架；这些目录由使用者本地自行产生，
# 部署脚本会按需自动创建空目录（见 deploy/install.ps1）。
# 注意：保留 workspace/.learnings 与 workspace/tools 等框架目录。

# 小说项目（所有者本人的异兽学院等创作，非框架）
/novel/

# 个人知识库（gbrain 向量库，首次运行由使用者初始化）
/gbrain/

# 工作区内私有数据
/workspace/memory/
/workspace/_协作基础设施_/
/workspace/archive/
/workspace/_douyin_learnings_/
/workspace/qclaw_项目中枢/
/workspace/山海巨兽录_产出/
/workspace/每日热点/
/workspace/每日热点共享池/
/workspace/赛马共享池/

# 个人 Agent 用户画像（使用者应自建 USER.md，参见 USER.md.example）
/workspace/USER.md

# 框架运行时自动生成的目录（含个人路径/状态，重新运行即再生，不发布）
/workspace/.learnings/.learnings/
/workspace/.learnings/archive/
/workspace/.learnings/knowledge-inbox/

# 仪表盘数据（含个人项目统计，使用者本地产生）
/workspace/dashboard/project-data.json

# 团队配置（真实员工名册与 SOUL 文件，使用者自行组建团队）
/workspace/团队配置/

# 用户级记忆/身份/心跳（高度个性化，参见 workspace/USER.md.example）
/workspace/HEARTBEAT.md
/workspace/IDENTITY.md
/workspace/MEMORY.md
/workspace/MEMORY-RULES.md
/workspace/MEMORY-PROFILE.md
/workspace/MEMORY-STATUS.md
