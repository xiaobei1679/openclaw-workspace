# ============================================================
# QClaw Agent Workspace — 环境变量模板
# 复制本文件为 .env（或直接在 shell / 系统环境变量中设置），
# 把等号右边替换成你自己的值即可。所有变量均为可选，
# 未设置时脚本会自动回退到当前用户目录下的合理默认值。
# ============================================================

# ---------- 网关 / 通道鉴权（原明文已移除，必须改为环境变量）----------
# 1) OpenClaw 网关鉴权 token（来自你的网关/控制台）
QCLAW_GATEWAY_TOKEN=

# 2) 企业微信通道（wechat-access）凭证
WECHAT_ACCESS_TOKEN=
WECHAT_GUID=
WECHAT_USER_ID=
# 企业微信 WebSocket 接入地址（含 wss:// 前缀）
QCLAW_WECHAT_WS_URL=

# ---------- 路径（跨用户/跨平台，默认回退到当前用户目录）----------
# OpenClaw 用户数据根目录，如 ~/.qclaw
# 默认：<HOME>/.qclaw
QCLAW_USER_DATA_DIR=

# OpenClaw 自带配置目录（含版本号的那层），如 C:\Program Files\QClaw\vX.Y.Z\resources\openclaw\config
# 默认：<仓库>/config 的同级约定路径；仅在你把 bundled config 放到别处时需要改
QCLAW_BUNDLED_CONFIG_DIR=

# 你的项目产出根目录（小说/方案/知识库/审核报告等都会放在这里）
# 默认：<HOME>/Desktop/QClaw产出文件
# 想沿用自己已有的旧目录，设这一项即可（路径换成你自己的）：
# QCLAW_PROJECT_DIR=C:\Users\你的用户名\Desktop\我的小说产出
QCLAW_PROJECT_DIR=

# 每日热点汇总目录
# 默认：<HOME>/Desktop/每日热点
QCLAW_HOT_DIR=

# 知识库目录（skill-discovery 扫描用）
# 默认：<HOME>/Desktop/QClaw产出文件/知识库
QCLAW_KNOWLEDGE_DIR=

# ---------- 可选：外部服务 ----------
# gbrain 向量化 embedding 用的 OpenAI API Key（没有则 gbrain 退化为全文检索）
OPENAI_API_KEY=
