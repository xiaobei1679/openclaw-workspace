# ============================================================
# AI Multi-Agent Workspace — 环境变量模板
# 复制本文件为 .env（或直接在 shell / 系统环境变量中设置），
# 把等号右边替换成你自己的值即可。所有变量均为可选，
# 未设置时脚本会自动回退到当前用户目录下的合理默认值。
# ============================================================

# ---------- 网关 / 通道鉴权（必须改为环境变量）----------
# 网关鉴权 token（来自你的网关/控制台）
GATEWAY_TOKEN=

# 企业微信通道凭证（接企业微信才需要）
WECHAT_ACCESS_TOKEN=
WECHAT_GUID=
WECHAT_USER_ID=
# 企业微信 WebSocket 接入地址（含 wss:// 前缀）
WECHAT_WS_URL=

# ---------- 路径（跨用户/跨平台，默认回退到当前用户目录）----------
# 用户数据根目录，如 ~/.agent-workspace
USER_DATA_DIR=

# 平台自带配置目录（含版本号的那层）
# 默认：<仓库>/config 的同级约定路径；仅在你把 bundled config 放到别处时需要改
BUNDLED_CONFIG_DIR=

# 项目产出根目录（小说/方案/知识库/审核报告等都会放在这里）
# 默认：<HOME>/Desktop/项目产出
PROJECT_DIR=

# 每日热点汇总目录
# 默认：<HOME>/Desktop/每日热点
HOT_DIR=

# 知识库目录（skill-discovery 扫描用）
# 默认：<PROJECT_DIR>/知识库
KNOWLEDGE_DIR=

# ---------- 可选：外部服务 ----------
# 向量化 embedding 用的 API Key（没有则退化为全文检索）
OPENAI_API_KEY=
