  "skills": {
    "limits": {
      "maxSkillsPromptChars": 20000
    },
    "load": {
      "extraDirs": [
        "${QCLAW_BUNDLED_CONFIG_DIR}\\skills",
        "~/.agents/skills",
        "${QCLAW_USER_DATA_DIR}\\skills",
        "${QCLAW_USER_DATA_DIR}\\skillhub-skills"
      ]
    },
    "entries": {
      "skill-creator": {
        "enabled": false
      },
      "qclaw-skill-creator": {
        "enabled": true
      },
      "aippt": {
        "enabled": true
      },
      "ima": {
        "enabled": true
      },
      "qq-email-skill": {
        "enabled": true
      },
      "tencent-docs": {
        "enabled": true
      },
      "tencent-meeting-mcp": {
        "enabled": true
      },
      "weiyun": {
        "enabled": true
      },
      "skill-vetter": {
        "enabled": true
      },
      "self-improvement": {
        "enabled": true
      },
      "self-improving": {
        "enabled": true
      },
      "bilibili-downloader": {
        "enabled": true
      },
      "video-frames": {
        "enabled": true
      },
      "openai-whisper": {
        "enabled": true
      },
      "imap-smtp-email": {
        "enabled": true
      }
    }
  },
  "models": {
    "mode": "merge",
    "pricing": {
      "enabled": false
    },
    "providers": {}
  },
  "tools": {
    "web": {
      "search": {
        "enabled": true,
        "provider": "yuanbao"
      }
    },
    "alsoAllow": [
      "sessions_spawn",
      "skillhub_install"
    ],
    "exec": {
      "pathPrepend": [
        "${QCLAW_BUNDLED_CONFIG_DIR}/bin",
        "${QCLAW_BUNDLED_CONFIG_DIR}/bin/node",
        "${QCLAW_BUNDLED_CONFIG_DIR}/bin/python",
        "${QCLAW_USER_DATA_DIR}/runtime-data/python/user-base/cpython-311-win32-x64/Python311/Scripts",
        "${QCLAW_BUNDLED_CONFIG_DIR}/bin/git"
      ]
    }
  },
  "browser": {
    "enabled": true,
    "defaultProfile": "openclaw",
    "ssrfPolicy": {
      "dangerouslyAllowPrivateNetwork": false
    }
  },
  "gateway": {
    "port": 61659,
    "mode": "local",
    "bind": "loopback",
    "auth": {
      "mode": "token",
      "token": "${QCLAW_GATEWAY_TOKEN}"
    },
    "controlUi": {
      "allowedOrigins": [
        "null",
        "file://"
      ]
    },
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    },
    "http": {
      "endpoints": {
        "chatCompletions": {
          "enabled": true
        }
      }
    }
  },
  "channels": {
    "wechat-access": {
      "enabled": true,
      "token": "${WECHAT_ACCESS_TOKEN}",
      "wsUrl": "${QCLAW_WECHAT_WS_URL}",
      "guid": "${WECHAT_GUID}",
      "userId": "${WECHAT_USER_ID}"
    }
  },
  "plugins": {
    "enabled": true,
    "allow": [
      "wechat-access",
      "qclaw-plugin",
      "qclaw-embedding",
      "memory-core",
      "ollama",
      "lossless-claw",
      "qclaw-llm-provider"
    ],
    "slots": {
      "contextEngine": "lossless-claw"
    },
    "load": {
      "paths": [
        "${QCLAW_BUNDLED_CONFIG_DIR}\\extensions"
      ]
    },
    "entries": {
      "wechat-access": {
        "enabled": true
      },
      "qclaw-plugin": {
        "enabled": true,
        "config": {},
        "hooks": {
          "allowConversationAccess": true
        }
      },
      "ollama": {
        "enabled": true
      },
      "lossless-claw": {
        "enabled": true,
        "config": {
          "dbPath": "${QCLAW_USER_DATA_DIR}\\memory\\lossless\\lcm.db",
          "contextThreshold": 0.6,
          "freshTailCount": 64,
          "freshTailMaxTokens": 40000,
          "incrementalMaxDepth": 5,
          "ignoreSessionPatterns": [
            "agent:*:cron:**",
            "**:heartbeat"
          ],
          "statelessSessionPatterns": [
            "agent:*:subagent:**"
          ],
          "skipStatelessSessions": true
        },
        "hooks": {
          "allowConversationAccess": true
        }
      },
      "qclaw-llm-provider": {
        "enabled": true,
        "config": {}
      }
    }
  },
  "messages": {
    "queue": {
      "mode": "followup"
    }
  },
  "session": {
    "reset": {
      "mode": "idle",
      "idleMinutes": 525600
    },
    "maintenance": {
      "pruneAfter": "365d",
      "maxEntries": 1000000,
      "resetArchiveRetention": false
    },
    "dmScope": "per-channel-peer"
  }
}