{
  "agents": {
    "defaults": {
      "model": {
        "primary": "qclaw/pool-glm-5.2"
      },
      "workspace": "${QCLAW_USER_DATA_DIR}\\workspace",
      "maxConcurrent": 3,
      "timeoutSeconds": 72000,
      "heartbeat": {
        "isolatedSession": true,
        "lightContext": true,
        "model": "qclaw/modelroute",
        "every": "2h"
      },
      "memorySearch": {
        "enabled": false,
        "provider": "auto"
      },
      "compaction": {
        "reserveTokensFloor": 80000,
        "memoryFlush": {
          "enabled": true,
          "softThresholdTokens": 45000
        }
      },
      "subagents": {
        "allowAgents": [
          "main",
          "agent-bdd9ff1a",
          "ds4ygtfdv3z7mmxn",
          "bg0wgtn9jlge3doh",
          "ua58rsb93veqtxl7",
          "ic7xj738h4v8p6g7",
          "worldview-architect",
          "media-producer",
          "biz-strategist"
        ]
      },
      "contextPruning": {
        "mode": "cache-ttl",
        "ttl": "5m",
        "softTrimRatio": 0.3,
        "hardClearRatio": 0.5
      }
    },
    "list": [
      {
        "id": "main",
        "default": true,
        "reasoningDefault": "stream",
        "name": "QClaw",
        "identity": {
          "name": "QClaw"
        },
        "skills": [
          "find-skills",
          "qclaw-cron-skill",
          "qclaw-env",
          "qclaw-rules",
          "qclaw-skill-creator",
          "xbrowser",
          "another_them",
          "persona-switch",
          "docx",
          "email-skill",
          "pdf",
          "xlsx",
          "aippt",
          "qq-email-skill",
          "tencent-docs",
          "ima",
          "tomato-novelist",
          "self-improvement",
          "qclaw-generate-image",
          "tencentmap-jsapi-gl-skill",
          "skill-vetter",
          "self-improving",
          "bilibili-downloader",
          "video-frames",
          "openai-whisper"
        ]
      },
      {
        "id": "bg0wgtn9jlge3doh",
        "name": "质量诊断官",
        "workspace": "${QCLAW_USER_DATA_DIR}\\workspace-bg0wgtn9jlge3doh",
